{
  "name": "lotus-wisdom-mcp",
  "version": "0.8.0",
  "description": "Contemplative reasoning MCP server — Lotus Sutra wisdom framework with interactive ext-apps journey visualization.",
  "main": "dist/bundle.js",
  "module": "index.ts",
  "type": "module",
  "bin": {
    "lotus-wisdom": "cli.js"
  },
  "files": [
    "dist/bundle.js",
    "dist/journey.html",
    "cli.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:app": "cd app && bun install --frozen-lockfile && bunx vite build",
    "build": "bun run build:app && rm -rf dist && tsc && cp app/dist/mcp-app.html dist/journey.html && bunx esbuild index.ts --bundle --platform=node --format=esm --outfile=dist/bundle.js",
    "start": "node dist/bundle.js",
    "dev": "tsc && node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "sync-version": "node scripts/sync-version.mjs",
    "prepublishOnly": "bun run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/linxule/lotus-wisdom-mcp.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "lotus-sutra",
    "wisdom",
    "contemplative-reasoning",
    "ext-apps",
    "claude",
    "ai-tools"
  ],
  "author": "Xule Lin",
  "license": "MIT",
  "mcpName": "io.github.linxule/lotus-wisdom",
  "bugs": {
    "url": "https://github.com/linxule/lotus-wisdom-mcp/issues"
  },
  "homepage": "https://github.com/linxule/lotus-wisdom-mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "esbuild": "^0.28.1",
    "typescript": "^5.9.0",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
